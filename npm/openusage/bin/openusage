#!/usr/bin/env node
"use strict";

const { execFileSync, spawnSync } = require("child_process");
const path = require("path");
const fs = require("fs");

function findBinary() {
  const binPath = path.join(__dirname, "openusage-bin");

  if (fs.existsSync(binPath)) {
    return binPath;
  }

  throw new Error(
    "Could not find the openusage binary.\n" +
      "The postinstall script may have failed to download it.\n" +
      "Try reinstalling: npm install -g @mwz-code/openusage\n" +
      "Or download manually from https://github.com/MWZ-Code/openusage-cli/releases"
  );
}

function main() {
  const binPath = findBinary();

  // Ensure the binary is executable
  try {
    fs.chmodSync(binPath, 0o755);
  } catch {
    // Ignore — may fail on read-only filesystems
  }

  // Resolve plugins directory: bundled with the root package
  const pluginsDir = path.join(__dirname, "..", "plugins");

  // Build args, injecting --plugins-dir if not already specified
  const args = process.argv.slice(2);
  if (!args.includes("--plugins-dir")) {
    args.unshift("--plugins-dir", pluginsDir);
  }

  const env = {
    ...process.env,
    OPENUSAGE_PLUGINS_DIR: pluginsDir,
  };

  try {
    execFileSync(binPath, args, { stdio: "inherit", env });
  } catch (err) {
    if (err.code === "EACCES") {
      const result = spawnSync(binPath, args, {
        stdio: "inherit",
        shell: true,
        env,
      });
      process.exit(result.status || 0);
    }
    if (err.status != null) {
      process.exit(err.status);
    }
    throw err;
  }
}

main();
